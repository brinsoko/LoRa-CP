# Flask app secrets
SECRET_KEY=change-me
LORA_WEBHOOK_SECRET=change-me-too

# Google Sheets sync (service account)
GOOGLE_SERVICE_ACCOUNT_FILE=google_sa.json
SHEETS_SYNC_ENABLED=1

# Google OAuth login
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Domain + ACME email for HTTPS (Caddy/Let’s Encrypt)
DOMAIN=example.com
ACME_EMAIL=you@example.com

# HMAC for NFC card writeback
DEVICE_CARD_SECRET=change-this-secret
DEVICE_CARD_HMAC_LEN=12
